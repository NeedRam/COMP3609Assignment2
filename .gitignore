# =============================================================================
# COMP 3609 Assignment 2 - Java Game Development Project
# Comprehensive .gitignore File
# =============================================================================
# This file excludes files that should NOT be committed to version control
# Categories include: compiled outputs, IDE configs, OS files, assets, logs, etc.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. JAVA COMPILATION OUTPUTS (.class files)
# -----------------------------------------------------------------------------
# These are compiled bytecode files generated by the Java compiler.
# They are automatically generated from .java source files and should NOT
# be tracked because they can be regenerated from source.
# 
# Pattern breakdown:
#   **/           - Match in any directory (recursive)
#   *.class       - Match any file ending with .class
#   !$src/        - But NOT if it's in a directory called "src" (if needed)

# All .class files in any directory (recursive)
**/*.class

# Specific inner class patterns that Java generates
# Example: Animation$AnimFrame.class, GameWindow$1.class
**/*$*.class

# -----------------------------------------------------------------------------
# 2. IDE CONFIGURATION FILES
# -----------------------------------------------------------------------------
# Each IDE stores its own configuration that shouldn't be shared as it can
# contain user-specific settings, paths, and preferences.

# ----- Eclipse IDE -----
# Eclipse workspace and project configuration
.metadata/
.bin/
.classpath
.project
.settings/

# Eclipse launch configurations (user-specific)
*.launch

# Eclipse temporary files
\.metadata/
.plugins/

# ----- IntelliJ IDEA -----
# IntelliJ IDEA module and workspace files
*.iml
*.ipr
*.iws
.idea/

# IntelliJ IDEA output directory
out/
target/

# ----- VS Code -----
# VS Code workspace settings (user-specific)
.vscode/
*.code-workspace

# ----- NetBeans IDE -----
# NetBeans project configuration
nbproject/
build.xml
nbbuild.xml
dist/
nbdist/
nbactions.xml
nb-configuration.xml

# ----- JCreator / Other IDEs -----
# JCreator project files
*.vcxproj
*.vcxproj.filters

# -----------------------------------------------------------------------------
# 3. BUILD DIRECTORIES AND OUTPUTS
# -----------------------------------------------------------------------------
# Directories created by build tools that can be regenerated

# Standard Java build output directory
bin/
build/

# Compiled libraries/jar files
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar

# Distribution and release directories
dist/
release/
publish/

# Maven build outputs
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties

# Gradle build outputs
.gradle/
build/

# -----------------------------------------------------------------------------
# 4. OPERATING SYSTEM SPECIFIC FILES
# -----------------------------------------------------------------------------
# Files created by the operating system that are not relevant to the project

# ----- Windows -----
# Windows thumbnail cache
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db

# Windows file lock/directory info
.DS_Store
Desktop.ini

# Windows temporary files
*.tmp
*.temp
~*

# Windows log files
*.log

# Windows shortcut files
*.lnk

# ----- macOS -----
# macOS system files
.DS_Store
.AppleDouble
.LSOverride
._*

# macOS resource forks
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# ----- Linux -----
# Linux system files
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# -----------------------------------------------------------------------------
# 5. AUDIO AND IMAGE ASSETS
# -----------------------------------------------------------------------------
# GAME ASSETS - Excluded from version control:
# 
# These binary files are excluded because:
# 1. Large binary files bloat the repository
# 2. Git doesn't handle binary files efficiently
# 3. They can be regenerated or re-added separately
# 4. Use Git LFS for large assets if needed

# -----------------------------------------------------------------------------
# 6. LOG FILES
# -----------------------------------------------------------------------------
# Log files created during runtime that shouldn't be tracked

# Java application logs
*.log
logs/
*.log.*

# Log4j logs
logs/
log4j/

# Application-specific logs
game.log
error.log
debug.log
trace.log

# -----------------------------------------------------------------------------
# 7. TEMPORARY FILES
# -----------------------------------------------------------------------------
# Temporary files created during development or runtime

# Java temporary files
*.bak
*.swp
*.swo
*~
*.orig

# Patch files
*.patch
*.diff

# Temporary directories
tmp/
temp/
.cache/

# ----- Java Specific Temporary Files -----
# Java compiler annotations (optional, generated)
.classpath.local

# Java Web Start (JWS) cache
.jnlp/

# Java security policy files
.policy

# ----- Backup Files -----
# Editor and system backup files
*#
*.Backup*
*_backup*
*_copy*

# -----------------------------------------------------------------------------
# 8. DEVELOPMENT SPECIFIC FILLES
# -----------------------------------------------------------------------------
# Files related to development process that shouldn't be tracked

# Batch files for building/running (platform-specific)
# We track .bat files as they are needed, but if you want to exclude:
# *.bat
# *.cmd
# *.sh

# Documentation that shouldn't be tracked (if auto-generated)
*.pdf
*.doc
*.docx
*.txt
!README.md
!LICENSE.md
!CONTRIBUTING.md

# Compiled documentation
docs/_build/
site/

# -----------------------------------------------------------------------------
# 9. EXAMPLE AND REFERENCE FILES
# -----------------------------------------------------------------------------
# Example files from previous weeks - Note on tracking:
# 
# The Examples/ folder contains reference materials from previous courses.
# You may want to:
# - Track them if they're needed for the assignment
# - Exclude them if they're just for reference and not part of your submission
# 
# Current decision: EXCLUDE Examples/ as they are reference materials,
# not part of your assignment submission.

# Exclude all example directories
Examples/

# -----------------------------------------------------------------------------
# 10. ADDITIONAL JAVA SPECIFIC PATTERNS
# -----------------------------------------------------------------------------
# Additional Java-related files to exclude

# Java source packages (compiled classes structure)
# These are automatically generated and not needed in version control
package/

# JUnit test reports
test-output/
junit/

# Jacoco code coverage reports
jacoco/
*.exec

# PMD analysis reports
pmd/
*.pmd

# Checkstyle analysis reports
checkstyle/

# FindBugs analysis reports
findbugs/

# -----------------------------------------------------------------------------
# 11. ENVIRONMENT AND CONFIGURATION
# -----------------------------------------------------------------------------
# Environment-specific configuration files that may contain sensitive data

# Environment variables files (may contain secrets)
.env
.env.local
.env.*.local

# Configuration files with sensitive data
config.properties
application.properties
!config.example.properties

# Database connection files
*.db
*.sqlite
*.h2

# API keys and secrets
api-keys.properties
secrets.properties

# -----------------------------------------------------------------------------
# 12. PROJECT SPECIFIC EXCLUSIONS
# -----------------------------------------------------------------------------
# Specific exclusions for this COMP 3609 Assignment 2 project

# Planning and documentation files
plans/

# The rebuild batch file is tracked (needed for building)
# If you want to exclude it:
# "rebuild and run.bat"

# Assignment guidelines (not needed in repo)
# "COMP 3609 Assignment Guidelines.md"
# "COMP 3609 Assignment Guidelines.pdf"

# -----------------------------------------------------------------------------
# IMPORTANT NOTES:
# -----------------------------------------------------------------------------
# 1. Order matters: More specific rules should come before general rules
# 2. Patterns starting with ! negate a previous exclusion (include instead)
# 3. Use ** for recursive matching, * for single-level matching
# 4. Test your .gitignore with: git check-ignore -v <file>
# 5. To see what's currently ignored: git status --ignored
# 
# For more information, visit: https://github.com/github/gitignore
# -----------------------------------------------------------------------------
